# car-agent environment — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# ── AI provider ───────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
# Stronger model used only for trim-level research (full spec extraction).
# Defaults to gpt-4o if unset.
TRIM_MODEL=gpt-4o

# ── Zoho CRM (custom function apikey / zapikey) ───────────────
ZOHO_APIKEY=1003.xxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# ── carimagesapi.com (image fallback) ─────────────────────────
CARIMAGES_API_KEY=ci_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CARIMAGES_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Image storage ─────────────────────────────────────────────
IMAGES_DIR=/var/www/car-images
IMAGES_BASE_URL=https://images.gsmdev.co.il/car-images
